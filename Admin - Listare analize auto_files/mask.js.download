/**
 * Initialises the money mask
 * @returns {void}
 */

function initFormattedFieldMask() {
  let fields = $('.float, .decimal');
  fields.each(function (index, element) {
    let $element = $(element);
    let isDecimalField = $element.hasClass('decimal');
    let formattedAttr = isDecimalField ? 'decimal-formatted' : 'float-formatted';

    if ($element.attr(formattedAttr) === true) {
      return true;
    }

    $element.on('keydown', function (e) {
      let start = this.selectionStart,
          end = this.selectionEnd;
      let field = $(e.target);

      if (e.keyCode === 8 && !Number.isInteger(parseInt(field.val().charAt(start - 1)))) {
        this.setSelectionRange(start - 1, end - 1);
        e.preventDefault();
      }

      if (e.keyCode === 46 && !Number.isInteger(parseInt(field.val().charAt(start)))) {
        this.setSelectionRange(start + 1, end + 1);
        e.preventDefault();
      }
    });
    $element.on('keyup', function (e) {
      let start = this.selectionStart,
          end = this.selectionEnd;
