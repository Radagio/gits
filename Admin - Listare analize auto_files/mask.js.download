        newDotCount = newVal.match(/([.])/g) !== null ? newVal.match(/([.])/g).length : 0;
        field.val(newVal);
        field[0].dispatchEvent(new Event('input'));
      }

      this.setSelectionRange(start + (newDotCount - oldDotCount), end + (newDotCount - oldDotCount));
    });

    if ($element.val() === "") {
      $element.val('');
    } else if (Number.isNaN(parseFloat($element.val())) || parseFloat($element.val()) === 0) {
