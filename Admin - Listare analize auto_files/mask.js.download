}

function formatWithPeriodsAndCommas(value) {
  let [integerPart, decimalPart] = value.split('.');

  if (decimalPart) {
    decimalPart = decimalPart.padEnd(3, '0');
  } else {
    decimalPart = '000';
  }

  integerPart = integerPart.replace(/\B(?=(\d{3})+(?!\d))/g, '.');
  return `${integerPart},${decimalPart}`;
}

