        break;

      case false:
        this._compact();

        break;
    }
  }
  /**
   * @returns {void}
   * @private
   */


  _compact() {
    let $table = this.table.getTable();
    $table.addClass('table-compact');
    this.compactButton.find('i').removeClass('fa-toggle-off');
    this.compactButton.find('i').addClass('fa-toggle-on');
    $table.trigger('table-compacted');
  }
  /**
   * @returns {void}
   * @private
   */


  _UnCompact() {
    let $table = this.table.getTable();
    $table.removeClass('table-compact');
    this.compactButton.find('i').removeClass('fa-toggle-on');
    this.compactButton.find('i').addClass('fa-toggle-off');
    $table.trigger('table-un-compacted');
  }

}

