      this._compact();
    } else {
      this._UnCompact();
    }

    this.compactButton.on('click', () => this._toggleCompactTable()); // console.log('compactListService.init', this.table.hasTooltipsDisabled() === false);

    if (this.table.hasTooltipsDisabled() === false) {
      this.ellipsisTooltipService.init();
    }
  }
  /**
