   */


  getTable() {
    return this._$table;
  }
  /**
   * @returns {boolean}
   * @public
   */


  hasTooltipsDisabled() {
    // console.log('tooltips disabled?', this._$table.hasClass('tooltips-disabled'));
    return this._$table.hasClass('tooltips-disabled');
  }
  /**
   * @returns {*|jQuery|Array}
   * @public
   */


  getTableHead() {
    return this._$table.find('thead');
  }
  /**
   * @returns {*|jQuery|Array}
   * @public
   */


  getTableBody() {
    return this._$table.find('tbody');
  }
  /**
   * @returns {*|jQuery|Array}
   * @public
   */


  getTableHeadRows() {
    return this._$table.find('thead > tr');
  }
  /**
   * @returns {*|jQuery|Array}
   * @public
   */


  getTableBodyRows() {
    let $rows = this._$table.find('tbody > tr');

    let rowsArray = [];
    $.each($rows, (index, element) => {
      rowsArray.push($(element));
    });
    return rowsArray;
  }
  /**
