class TableEllipsisTooltipService extends _EllipsisTooltipService__WEBPACK_IMPORTED_MODULE_0__["default"] {
  /**
   * @param {TableObject} table
   * @constructor
   */
  constructor(table) {
    super();
    this.table = table;
  }
  /**
   * @returns {void}
   * @public
   */


  init() {
    this._toggleTooltips();

    this.table.getTable().on('table-compacted table-un-compacted', () => this._toggleTooltips());
  }
  /**
   * @returns{void}
   * @private
   */


  _toggleTooltips() {
    $.each(this.table.getTableBody().find('td'), (index, element) => {
      if ($(element).find('.relation-value').length > 0) {
        return true;
      }

      if (this._hasEllipsis(element)) {
        this._addTooltip(element);
      } else {
        this._removeTooltip(element);
      }
    });
  }

}

