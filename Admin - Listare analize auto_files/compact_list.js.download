class EllipsisTooltipService {
  /**
   * @param {jQuery} subject
   * @param {String} event
   * @public
   */
  init(subject, event) {
    this._toggleTooltips(subject);

    if (typeof event !== "undefined") {
      subject.on(event, () => this._toggleTooltips(subject));
    }
  }
  /**
   * @returns{void}
   * @param {jQuery} subject
   * @private
   */


  _toggleTooltips(subject) {
    $.each(subject, (index, element) => {
      if (this._hasEllipsis(element)) {
        this._addTooltip(element);
      } else {
        this._removeTooltip(element);
      }
    });
  }
  /**
   * @param {HTMLBaseElement} element
   * @returns {boolean}
   * @private
   */


  _hasEllipsis(element) {
    return element.offsetWidth < element.scrollWidth;
  }
  /**
   * @param {HTMLBaseElement} element
   * @returns {void}
   * @private
   */


  _addTooltip(element) {
    let $element = $(element);
    let $tooltip = $('<span data-placement="left" data-html=true data-toggle="tooltip">');
    $tooltip.html($element.html());
    $tooltip.attr('title', $tooltip.html());
    $element.html('');
    $element.append($tooltip);
    $tooltip.tooltip();
  }
  /**
   * @param {HTMLBaseElement} element
   * @returns {void}
   * @private
   */


  _removeTooltip(element) {
    let $element = $(element);
    let $tooltip = $element.find('span[data-toggle="tooltip"]');
    $tooltip.remove();
    $element.html($tooltip.html());
  }

}

