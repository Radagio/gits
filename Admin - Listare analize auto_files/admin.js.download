Admin.__nativeSelectLocations = ['transhipment', 'shipsituationdetail', 'interruption', 'maneuver'];

Admin.setup_select2 = function (subject) {
  if (Admin.get_config('USE_SELECT2') && Admin.__isSelect2Allowed()) {
    Admin.log('[core|setup_select2] configure Select2 on', subject);
    jQuery('select:not([data-sonata-select2="false"])', subject).each(function () {
      var select = jQuery(this);
      var allowClearEnabled = false;
      var popover = select.data('popover');
      select.removeClass('form-control');

      if (select.find('option[value=""]').length || select.attr('data-sonata-select2-allow-clear') === 'true') {
        allowClearEnabled = true;
      } else if (select.attr('data-sonata-select2-allow-clear') === 'false') {
        allowClearEnabled = false;
      }

      select.select2({
        width: function () {
          // Select2 v3 and v4 BC. If window.Select2 is defined, then the v3 is installed.
          // NEXT_MAJOR: Remove Select2 v3 support.
          return Admin.get_select2_width(window.Select2 ? this.element : select);
        },
        dropdownAutoWidth: true,
        minimumResultsForSearch: 10,
        allowClear: allowClearEnabled
      });

      if (undefined !== popover) {
        select.select2('container').popover(popover.options);
      }
    });
  }
};

Admin.__isSelect2Allowed = function () {
  if (!isMobileRequest) {
    return true;
  }

  let allowed = true;

  for (let locationIndex in Admin.__nativeSelectLocations) {
    let location = Admin.__nativeSelectLocations[locationIndex];

    if (window.location.href.search(location) !== -1) {
      allowed = false;
    }
  }

  return allowed;
};

Admin.setup_xeditable = function (subject) {
  Admin.log('[core|setup_xeditable] configure xeditable on', subject);
  jQuery('.x-editable', subject).editable({
    emptyclass: 'editable-empty btn btn-sm btn-default',
    emptytext: '<i class="fa fa-pencil"></i>',
    container: 'body',
    placement: 'auto',
    success: function (response) {
      var html = jQuery(response);
      Admin.setup_xeditable(html);
      jQuery(this).closest('td').replaceWith(html);
      let td = html.length > 1 ? html[2] : html;
      jQuery(td).trigger('x-editable-success');
    },
    error: function (xhr, statusText, errorThrown) {
      return xhr.responseJSON;
    }
  });
};

Admin.setup_form_filters = function () {
  let shouldHide = false;
  jQuery('form.sonata-filter-form .col-sm-8 .form-group').each(function (index, element) {
    if ($(element).is(':visible')) {
      shouldHide = false;
      return false;
    }

    shouldHide = true;
  });

  if (shouldHide) {
    jQuery('.sonata-filters-box').hide();
  }
};

Admin.read_config = function () {
  let data = $('[data-sonata-admin]').data('sonata-admin');
  this.config = data.config;
  this.translations = data.translations;

  if (typeof CONFIRM_EXIT !== "undefined") {
    this.config.CONFIRM_EXIT = CONFIRM_EXIT;
  }
};

jQuery(document).on('row-added', e => {
  Admin.setup_xeditable(e.target);
});
jQuery(document).on('vue-component-initialized', function (e) {
  Admin.setup_select2(e.target);
});
