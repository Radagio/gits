/***/ (function(module, __webpack_exports__, __webpack_require__) {

"use strict";
__webpack_require__.r(__webpack_exports__);


class FormDialogHelper {
  /**
   * Initialises BootstrapDialog window for the form action specified
   * @param $button
   */
  static openFormDialogOnClick($button) {
    let url = $button.data('dialog-url');
    let successUrl = $button.data('dialog-success-url');
    let title = $button.data('dialog-title');
    let type = $button.data('dialog-type');
    let actionLabel = $button.data('dialog-action-label');
    let actionType = $button.data('dialog-action-type');
    let cancelLabel = $button.data('dialog-cancel-label');
    let formSubmit = $button.data('dialog-form-submit');
    $.ajax({
      url: url
    }).done(function (data) {
      let dialog = BootstrapDialog.show({
        title: title ? title : null,
        type: type ? type : BootstrapDialog.TYPE_PRIMARY,
        message: function () {
          if (data.flag) {
            return $(data.form);
          }
        },
        buttons: [{
          id: 'btn-close',
          label: cancelLabel ? cancelLabel : null,
          cssClass: 'btn btn-default modal-cancel-button float-left',
          action: function (dialog) {
            dialog.close();
          }
        }, {
          id: 'btn-save',
          label: actionLabel ? actionLabel : null,
          cssClass: 'btn btn-' + (actionType ? actionType : 'primary'),
          hotkey: 13,
          action: function (dialog) {
            let button = $(this);
            let form = button.closest('.modal').find('form');
            button.attr('disabled', true);

            if (formSubmit) {
              form.submit();
              dialog.close();
            } else {
              $.ajax({
                type: "POST",
                url: url,
                data: new FormData(form[0]),
                cache: false,
                contentType: false,
                processData: false
              }).done(function (data) {
                if (data.flag === 'redirect') {
                  if (successUrl) {
                    window.location.replace(successUrl);
                  } else {
                    window.location.replace(data.url);
                  }
                } else if (data.flag === 'error') {
                  var formWithErrors = $(data.form);
                  var wrapper = form.closest('.bootstrap-dialog-message');
                  wrapper.find('.alert').remove();
                  form.remove();
                  wrapper.append(formWithErrors);
                  button.attr('disabled', false);
                  Admin.shared_setup(wrapper);
                }
              });
              dialog.setClosable(false);
            }
          }
        }]
      });
      Admin.shared_setup(dialog.$modal);
    });
  }

}

/* harmony default export */ __webpack_exports__["default"] = (FormDialogHelper);

